  <TBODY>
  <TR>
    <TD=20
    style=3D"PADDING-RIGHT: 0in; PADDING-LEFT: 0in; PADDING-BOTTOM: 0in; =
PADDING-TOP: 0in"=20
    vAlign=3Dtop align=3Dleft height=3D9>
      <P class=3DMsoNormal><SPAN style=3D"COLOR: black"><IMG height=3D9=20
      =
src=3D"file:///F:/&#1063;&#1058;&#1048;&#1042;&#1054;%20(&#1074;&#1090;&#=
1086;&#1088;&#1086;&#1089;&#1090;&#1077;&#1087;&#1077;&#1085;&#1085;&#108=
6;&#1077;)/mamb.ru%20(&#1052;&#1072;&#1083;&#1072;&#1103;%20&#1072;&#1082=
;&#1072;&#1076;&#1077;&#1084;&#1080;&#1103;%20&#1084;&#1086;&#1088;&#1089=
