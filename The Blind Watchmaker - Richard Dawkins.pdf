    <TD=20
    style=3D"PADDING-RIGHT: 0in; PADDING-LEFT: 0in; PADDING-BOTTOM: 0in; =
PADDING-TOP: 0in"=20
    vAlign=3Dtop align=3Dleft height=3D18>
      <P class=3DStyle25><I><SPAN style=3D"FONT-FAMILY: =
Times-Italic">The Blind=20
      Watchmaker </SPAN></I></P>
      <P class=3DStyle25><SPAN=20
      style=3D"COLOR: black; FONT-FAMILY: =
Times-Italic"></SPAN>&nbsp;</P></TD></TR></TBODY></TABLE></DIV><BR=20
clear=3Dall>
<DIV>
<TABLE height=3D607 cellSpacing=3D0 cellPadding=3D0 width=3D350 =
vspace=3D"0" hspace=3D"0">
  <TBODY>
  <TR>
    <TD=20
    style=3D"PADDING-RIGHT: 0in; PADDING-LEFT: 0in; PADDING-BOTTOM: 0in; =
PADDING-TOP: 0in"=20
    vAlign=3Dtop align=3Dleft height=3D607>
      <P class=3DMsoNormal><SPAN=20
      style=3D"FONT-SIZE: 10pt; COLOR: black; FONT-FAMILY: =
Times-Italic"><IMG=20
      height=3D607=20
      =
src=3D"file:///F:/&#1063;&#1058;&#1048;&#1042;&#1054;%20(&#1074;&#1090;&#=
1086;&#1088;&#1086;&#1089;&#1090;&#1077;&#1087;&#1077;&#1085;&#1085;&#108=
6;&#1077;)/mamb.ru%20(&#1052;&#1072;&#1083;&#1072;&#1103;%20&#1072;&#1082=
;&#1072;&#1076;&#1077;&#1084;&#1080;&#1103;%20&#1084;&#1086;&#1088;&#1089=
;&#1082;&#1086;&#1081;%20&#1073;&#1080;&#1086;&#1083;&#1086;&#1075;&#1080=
;&#1080;)/The%20Blind%20Watchmaker/The_Blind_Watchmaker_files/image029.jp=
g"=20
